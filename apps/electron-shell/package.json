{
  "name": "apps-electron-shell",
  "version": "0.0.1",
  "description": "ai-shell Electron application with secure process architecture",
  "private": true,
  "main": ".vite/build/index.js",
  "scripts": {
    "dev": "electron-forge start",
    "build": "electron-forge package",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist out .vite"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "electron-squirrel-startup": "1.0.1",
    "ignore": "7.0.5",
    "minimatch": "10.2.4",
    "monaco-editor": "0.55.1",
    "node-pty": "1.1.0",
    "packages-agent-tools": "workspace:*",
    "packages-api-contracts": "workspace:*",
    "packages-broker-main": "workspace:*",
    "packages-ui-kit": "workspace:*",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-webgl": "^0.16.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/core": "7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/shared-types": "^7.11.1",
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "10.4.27",
    "electron": "^40.7.0",
    "jsdom": "^28.1.0",
    "postcss": "8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
